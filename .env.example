# Kronos AI price forecaster (POST /prediction/predict).
# true (default outside Docker): loads the model at startup — needs torch +
# the Kronos repo at KRONOS_PATH. false: app runs without torch, /prediction
# returns 503, every other feature unaffected.
KRONOS_ENABLED=true
KRONOS_PATH=/path/to/Kronos

DEFAULT_MODEL=NeoQuasar/Kronos-small
DEFAULT_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base

DEFAULT_SYMBOL=BTCUSDT
DEFAULT_INTERVAL=5m
DEFAULT_LOOKBACK=400
DEFAULT_PRED_LEN=24

# --- Phase 5: AI (all 7 services route through NVIDIA NIM, one key) ---
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Per-service model override — only needed if NIM's catalog slug differs from
# the default below (check https://build.nvidia.com for the exact model ID).
# nemotron/deepseek/minimax slugs below are confirmed exact; glm/kimi are
# best-guess org-prefixed slugs — verify on build.nvidia.com if they 404.
MARKET_ANALYST_MODEL=nvidia/nemotron-3-super-120b-a12b
STRATEGY_SELECTOR_MODEL=zai-org/glm-5.1
TRADE_VALIDATOR_MODEL=deepseek-ai/deepseek-v4-pro
RISK_MANAGER_MODEL=zai-org/glm-5.1
SENTIMENT_ANALYZER_MODEL=minimaxai/minimax-m3
CHAT_ASSISTANT_MODEL=moonshotai/kimi-k2.5
BACKTEST_EXPLAINER_MODEL=minimaxai/minimax-m2.7

# --- Phase 7: Live trading (leave blank unless going live) ---
# Preferred: leave these blank and enter your keys on the Settings page
# instead — they're stored encrypted in the DB and used automatically.
# These env vars are only a fallback for anyone who wants env-only config.
BINANCE_API_KEY=
BINANCE_SECRET=
# Encrypts Binance credentials saved via the Settings page. Optional — if
# blank, derived from JWT_SECRET (set that instead of adding a new var).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=

# --- Phase 8: Database (blank = local SQLite, no setup needed) ---
DATABASE_URL=

# --- Phase 10: SaaS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

RATE_LIMIT_FREE=60/minute
RATE_LIMIT_PRO=300/minute
RATE_LIMIT_ENTERPRISE=2000/minute

# --- Deployment hardening (all optional; safe to leave blank for local dev) ---
# Set a strong random value to LOCK the money-critical endpoints (save/delete
# Binance keys, start/stop live trading, delete-all history) behind an
# X-Admin-Token header. REQUIRED before exposing this app on a public host.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=
# Return real exception text in API errors. Keep false in production.
DEBUG_ERRORS=false
# Blanket per-client request ceiling (DoS/cost backstop across all routes).
GLOBAL_RATE_LIMIT=240/minute

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- Docker Compose only ---
POSTGRES_USER=trading
# REQUIRED for docker compose — no default; use a strong random value.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
POSTGRES_DB=trading
KRONOS_PATH_HOST=./kronos
