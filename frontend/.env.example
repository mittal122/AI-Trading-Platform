# Backend location for the built frontend.
#
# LEAVE UNSET for: local dev (Vite proxy), Docker (nginx proxy), and the
# recommended Vercel setup (vercel.json rewrites /api to your tunnel).
#
# Set ONLY for direct cross-origin mode — the browser then calls the backend
# straight at this URL (enables the live paper-trading WebSocket on Vercel).
# The backend must allow the frontend origin via CORS_ALLOWED_ORIGINS.
# VITE_API_BASE_URL=https://your-tunnel.ngrok-free.app
